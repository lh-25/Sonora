# Django backend environment variables

SECRET_KEY=your-django-secret-key-here

# PostgreSQL (local dev)
# DATABASE_URL=postgres://...  (for Heroku, set as env var)

# AWS S3
S3_BUCKET=your-s3-bucket-name
S3_BASE_URL=https://s3.amazonaws.com/

# Spotify API (register at developer.spotify.com)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# For mobile app, use the Expo deep link scheme:
SPOTIFY_REDIRECT_URI=sonora://spotify-callback
